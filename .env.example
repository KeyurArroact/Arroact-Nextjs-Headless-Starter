# Environment Configuration
NEXT_PUBLIC_ENV=development

# GraphQL API Configuration
GRAPHQL_URL=https://localhost:44341/graphql
GRAPHQL_API_KEY=your-api-key-here

# Media URL Configuration (Optional)
# If not provided, will use GRAPHQL_URL without /graphql
# Example: https://localhost:44341
# MEDIA_URL=https://localhost:44341

# Root Content ID (Optional)
ROOT_CONTENT_ID=your-root-content-id
